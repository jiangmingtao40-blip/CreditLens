# DeepSeek配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8081
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=app.log
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=5

# 缓存配置
CACHE_RESULT_TTL=7200
CACHE_TASK_TTL=3600